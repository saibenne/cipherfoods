{
  "name": "@cipherfoods/source",
  "version": "0.0.1",
  "private": true,
  "description": "CipherFoods — Farmer-to-consumer eCommerce platform for traditional foods",
  "license": "UNLICENSED",
  "scripts": {
    "start:api": "nx serve api",
    "start:api:dev": "nx serve api --watch",
    "start:web": "nx serve web",
    "start:vendor": "nx serve vendor-panel",
    "start:admin": "nx serve admin-panel",
    "build:api": "nx build api",
    "build:web": "nx build web",
    "build:vendor": "nx build vendor-panel",
    "build:admin": "nx build admin-panel",
    "build:all": "nx run-many --target=build --all",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "test:api": "nx test api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "typeorm:migration:generate": "npx ts-node -r tsconfig-paths/register --project apps/api/tsconfig.app.json node_modules/typeorm/cli.js migration:generate -d apps/api/data-source.ts",
    "typeorm:migration:run": "npx ts-node -r tsconfig-paths/register --project apps/api/tsconfig.app.json node_modules/typeorm/cli.js migration:run -d apps/api/data-source.ts",
    "typeorm:migration:revert": "npx ts-node -r tsconfig-paths/register --project apps/api/tsconfig.app.json node_modules/typeorm/cli.js migration:revert -d apps/api/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/bullmq": "^10.2.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jwks-rsa": "^3.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "next": "^14.2.0",
    "razorpay": "^2.9.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@nx/eslint": "^19.0.0",
    "@nx/eslint-plugin": "^19.0.0",
    "@nx/jest": "^19.0.0",
    "@nx/js": "^19.0.0",
    "@nx/nest": "^19.0.0",
    "@nx/next": "^19.0.0",
    "@nx/node": "^19.0.0",
    "@nx/workspace": "^19.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "jest": "^29.7.0",
    "nx": "^19.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.19",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
