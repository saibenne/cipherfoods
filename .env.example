# ─── Application ───────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ─── Database (PostgreSQL) ─────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=cipherfoods

# ─── Redis ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Keycloak ──────────────────────────────
KEYCLOAK_BASE_URL=http://localhost:8180
KEYCLOAK_REALM=cipherfoods
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_CLIENT_SECRET=your-client-secret
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── Cloudinary ────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Razorpay ──────────────────────────────
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ─── Delivery (Dunzo/Porter) ──────────────
DELIVERY_PROVIDER=dunzo
DELIVERY_API_KEY=your-delivery-api-key
DELIVERY_API_BASE_URL=https://api.dunzo.in/api/v1

# ─── Freshdesk (Support) ──────────────────
FRESHDESK_DOMAIN=your-domain
FRESHDESK_API_KEY=your-api-key

# ─── AWS (Production) ─────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ─── JWT ───────────────────────────────────
JWT_ISSUER=http://localhost:8180/realms/cipherfoods
JWT_AUDIENCE=api-gateway
