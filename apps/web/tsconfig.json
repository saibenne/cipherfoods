{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "dom", "dom.iterable"],
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "strict": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@cipherfoods/shared": ["libs/shared/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts"
  ],
  "exclude": ["node_modules", ".next", "out", "dist"]
}
